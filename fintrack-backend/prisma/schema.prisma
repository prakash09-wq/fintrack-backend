generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String   @db.VarChar(100)
  email          String   @unique @db.VarChar(150)
  password_hash  String?
  firebase_uid   String?  @unique
  provider       String   @default("email") @db.VarChar(20)
  avatar_url     String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  transactions   Transaction[]
  assets         Asset[]
  liabilities    Liability[]
  loans          Loan[]
  goals          Goal[]
  budgets        Budget[]

  @@map("users")
}

model Transaction {
  txn_id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  type        TxnType
  amount      Decimal  @db.Decimal(12, 2)
  category    String   @db.VarChar(50)
  description String?
  date        DateTime @db.Date
  created_at  DateTime @default(now())

  user        User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("transactions")
}

enum TxnType {
  income
  expense
}

model Asset {
  asset_id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  name          String   @db.VarChar(100)
  type          String   @db.VarChar(50)
  value         Decimal  @db.Decimal(14, 2)
  date_recorded DateTime @default(now()) @db.Date
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user          User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("assets")
}

model Liability {
  liability_id  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  name          String   @db.VarChar(100)
  type          String   @db.VarChar(50)
  amount_owed   Decimal  @db.Decimal(14, 2)
  due_date      DateTime? @db.Date
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user          User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("liabilities")
}

model Loan {
  loan_id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String        @db.Uuid
  lender_name    String        @db.VarChar(100)
  principal      Decimal       @db.Decimal(14, 2)
  interest_rate  Decimal       @db.Decimal(5, 2)
  tenure_months  Int
  start_date     DateTime      @db.Date
  emi_amount     Decimal       @db.Decimal(12, 2)
  amount_paid    Decimal       @default(0) @db.Decimal(14, 2)
  status         LoanStatus    @default(active)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  user           User          @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  payments       LoanPayment[]

  @@map("loans")
}

enum LoanStatus {
  active
  closed
}

model LoanPayment {
  payment_id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loan_id        String   @db.Uuid
  month_label    String   @db.VarChar(20)
  emi_amount     Decimal  @db.Decimal(12, 2)
  principal_part Decimal  @db.Decimal(12, 2)
  interest_part  Decimal  @db.Decimal(12, 2)
  is_paid        Boolean  @default(false)
  payment_date   DateTime? @db.Date
  created_at     DateTime @default(now())

  loan           Loan     @relation(fields: [loan_id], references: [loan_id], onDelete: Cascade)

  @@map("loan_payments")
}

model Goal {
  goal_id       String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String     @db.Uuid
  name          String     @db.VarChar(100)
  target_amount Decimal    @db.Decimal(14, 2)
  saved_amount  Decimal    @default(0) @db.Decimal(14, 2)
  deadline      DateTime?  @db.Date
  status        GoalStatus @default(in_progress)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  user          User       @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("goals")
}

enum GoalStatus {
  in_progress
  achieved
}

model Budget {
  budget_id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  category      String   @db.VarChar(50)
  limit_amount  Decimal  @db.Decimal(12, 2)
  spent_amount  Decimal  @default(0) @db.Decimal(12, 2)
  month         Int
  year          Int
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user          User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([user_id, category, month, year])
  @@map("budgets")
}
