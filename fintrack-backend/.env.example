# ─── DATABASE ─────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/fintrack_db"

# ─── JWT ──────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production"
JWT_EXPIRES_IN="7d"

# ─── SERVER ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────
# Frontend URL (update after deploying frontend)
CLIENT_URL="http://localhost:3000"

# ─── FIREBASE ADMIN (for verifying Google tokens) ─────────────
# Download service account JSON from Firebase Console:
# Project Settings → Service Accounts → Generate new private key
# Then paste the values below from the downloaded JSON file
FIREBASE_PROJECT_ID="fintrack-47c01"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@fintrack-47c01.iam.gserviceaccount.com"
# For private key: copy the entire "private_key" value including \n characters
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
